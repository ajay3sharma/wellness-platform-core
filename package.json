{
  "name": "wellness-platform-core",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "node ./scripts/run-turbo.mjs dev",
    "dev:web": "node ./scripts/run-workspace-script.mjs @platform/web dev",
    "dev:admin": "node ./scripts/run-workspace-script.mjs @platform/admin dev",
    "dev:api": "node ./scripts/run-workspace-script.mjs @platform/api dev",
    "dev:mobile": "node ./scripts/run-workspace-script.mjs @platform/mobile dev",
    "build": "node ./scripts/run-turbo.mjs build",
    "lint": "node ./scripts/brand-check.mjs && node ./scripts/repo-check.mjs && node ./scripts/run-turbo.mjs lint",
    "typecheck": "node ./scripts/run-turbo.mjs typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "brand:check": "node ./scripts/brand-check.mjs",
    "repo:check": "node ./scripts/repo-check.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "eslint": "^9.24.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
