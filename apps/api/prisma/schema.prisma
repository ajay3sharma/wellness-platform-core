generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  coach
  admin
}

enum AccountStatus {
  active
  pending_approval
}

enum Market {
  india
  global
}

enum BillingProvider {
  razorpay
  stripe
}

enum UserPlan {
  free
  plus
  pro
}

enum WorkoutStatus {
  draft
  published
}

enum ContentStatus {
  draft
  published
}

enum BillingInterval {
  month
  year
}

enum CheckoutKind {
  cart
  subscription
}

enum CheckoutSurface {
  web
  mobile
}

enum BillingCheckoutSessionStatus {
  pending
  completed
  cancelled
  failed
  expired
}

enum OrderStatus {
  pending
  paid
  cancelled
  payment_failed
}

enum SubscriptionStatus {
  pending
  active
  cancelled
  payment_failed
}

enum AiProvider {
  gemini
}

enum AiFeatureKey {
  user_workout_recommendation
  user_reset_recommendation
  admin_workout_draft
  admin_relaxation_draft
}

enum AiUsageStatus {
  succeeded
  quota_blocked
  provider_unavailable
  disabled
  failed
}

enum WorkoutDifficulty {
  beginner
  intermediate
  advanced
}

enum WorkoutSessionStatus {
  in_progress
  completed
}

model User {
  id                     String                @id @default(cuid())
  email                  String                @unique
  displayName            String
  role                   Role                  @default(user)
  status                 AccountStatus         @default(active)
  requestedRole          Role?
  activeBrand            String
  passwordHash           String
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  refreshTokens          RefreshToken[]
  coachAssignment        UserCoachAssignment?  @relation("AssignedCoachForUser")
  assignedUsers          UserCoachAssignment[] @relation("CoachAssignments")
  coachAssignmentsCreated UserCoachAssignment[] @relation("CoachAssignedBy")
  workoutSessions        WorkoutSession[]
  workoutAssignments     WorkoutAssignment[]   @relation("AssignedWorkoutsForUser")
  workoutsAssignedBy     WorkoutAssignment[]   @relation("AssignedWorkoutsByCoach")
  coachNotes             CoachNote[]           @relation("CoachNotesForUser")
  coachNotesAuthored     CoachNote[]           @relation("CoachNotesByCoach")
  carts                  Cart[]
  orders                 Order[]
  checkoutSessions       BillingCheckoutSession[]
  subscriptions          UserSubscription[]
  productEntitlements    UserProductEntitlement[]
  aiUsageRecords         AiUsageRecord[]

  @@index([role])
  @@index([status])
  @@map("users")
}

model CatalogProduct {
  id            String               @id @default(cuid())
  title         String
  description   String
  category      String?
  tags          String[]
  coverImageUrl String?
  purchaseLabel String?
  status        ContentStatus        @default(draft)
  publishedAt   DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  prices        CatalogProductPrice[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  entitlements  UserProductEntitlement[]

  @@index([status])
  @@map("catalog_products")
}

model CatalogProductPrice {
  id          String         @id @default(cuid())
  productId   String
  market      Market
  currency    String
  amountMinor Int
  isCurrent   Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  product     CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, market, isCurrent])
  @@map("catalog_product_prices")
}

model SubscriptionPlan {
  id              String                  @id @default(cuid())
  name            String
  description     String
  userPlan        UserPlan
  billingInterval BillingInterval
  features        String[]
  status          ContentStatus           @default(draft)
  publishedAt     DateTime?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  prices          SubscriptionPlanPrice[]
  subscriptions   UserSubscription[]

  @@index([status])
  @@map("subscription_plans")
}

model SubscriptionPlanPrice {
  id                 String           @id @default(cuid())
  subscriptionPlanId String
  market             Market
  currency           String
  amountMinor        Int
  isCurrent          Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  subscriptionPlan   SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Cascade)

  @@index([subscriptionPlanId, market, isCurrent])
  @@map("subscription_plan_prices")
}

model Cart {
  id        String     @id @default(cuid())
  userId    String
  market    Market
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@unique([userId, market])
  @@map("carts")
}

model CartItem {
  id        String         @id @default(cuid())
  cartId     String
  productId  String
  quantity   Int           @default(1)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  cart       Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product    CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  id          String                 @id @default(cuid())
  userId       String
  provider     BillingProvider
  market       Market
  status       OrderStatus           @default(pending)
  currency     String
  amountMinor  Int
  paidAt       DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        OrderItem[]
  checkoutSession BillingCheckoutSession?
  entitlements UserProductEntitlement[]

  @@index([userId, createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId          String
  productId        String?
  title            String
  quantity         Int
  unitAmountMinor  Int
  totalAmountMinor Int
  coverImageUrl    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          CatalogProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

model UserSubscription {
  id                 String                  @id @default(cuid())
  userId             String
  subscriptionPlanId String
  planName           String
  userPlan           UserPlan
  billingInterval    BillingInterval
  provider           BillingProvider
  market             Market
  status             SubscriptionStatus      @default(pending)
  currency           String
  amountMinor        Int
  providerPlanId     String?
  providerSubscriptionId String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  activatedAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan   SubscriptionPlan        @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  checkoutSession    BillingCheckoutSession?

  @@index([userId, createdAt(sort: Desc)])
  @@index([providerSubscriptionId])
  @@map("user_subscriptions")
}

model UserProductEntitlement {
  id         String          @id @default(cuid())
  userId      String
  productId   String
  orderId     String
  title       String
  grantedAt   DateTime       @default(now())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     CatalogProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([orderId])
  @@map("user_product_entitlements")
}

model BillingCheckoutSession {
  id                  String                       @id @default(cuid())
  userId              String
  kind                CheckoutKind
  provider            BillingProvider
  market              Market
  status              BillingCheckoutSessionStatus @default(pending)
  targetSurface       CheckoutSurface
  launchToken         String                       @unique
  currency            String
  amountMinor         Int
  providerSessionId   String?
  providerOrderId     String?
  providerSubscriptionId String?
  providerCheckoutUrl String?
  successUrl          String
  cancelUrl           String
  expiresAt           DateTime
  completedAt         DateTime?
  snapshot            Json?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  orderId             String?                      @unique
  subscriptionId      String?                      @unique
  user                User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  order               Order?                       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  subscription        UserSubscription?            @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([providerSessionId])
  @@index([providerOrderId])
  @@index([providerSubscriptionId])
  @@map("billing_checkout_sessions")
}

model BillingWebhookReceipt {
  id              String          @id @default(cuid())
  provider        BillingProvider
  externalEventId String
  payload         Json
  receivedAt      DateTime        @default(now())
  processedAt     DateTime?

  @@unique([provider, externalEventId])
  @@map("billing_webhook_receipts")
}

model AiUsageRecord {
  id                  String        @id @default(cuid())
  userId              String
  role                Role
  activeBrand         String
  resolvedUserPlan    UserPlan?
  provider            AiProvider
  featureKey          AiFeatureKey
  usageDate           DateTime      @db.Date
  status              AiUsageStatus
  promptTokenCount    Int           @default(0)
  candidateTokenCount Int           @default(0)
  totalTokenCount     Int           @default(0)
  errorCode           String?
  metadata            Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usageDate, status])
  @@index([activeBrand, usageDate, role, status])
  @@index([featureKey, usageDate, status])
  @@map("ai_usage_records")
}

model RelaxationTechnique {
  id                       String           @id @default(cuid())
  title                    String
  description              String
  category                 String?
  tags                     String[]
  estimatedDurationMinutes Int
  coverImageUrl            String?
  status                   ContentStatus    @default(draft)
  publishedAt              DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  steps                    RelaxationStep[]

  @@index([status])
  @@map("relaxation_techniques")
}

model RelaxationStep {
  id                    String               @id @default(cuid())
  relaxationTechniqueId String
  title                 String
  instruction           String
  durationSeconds       Int
  sequence              Int
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  relaxationTechnique   RelaxationTechnique  @relation(fields: [relaxationTechniqueId], references: [id], onDelete: Cascade)

  @@index([relaxationTechniqueId])
  @@unique([relaxationTechniqueId, sequence])
  @@map("relaxation_steps")
}

model MusicTrack {
  id              String        @id @default(cuid())
  title           String
  description     String
  category        String?
  tags            String[]
  artistName      String
  durationSeconds Int
  audioUrl        String
  artworkUrl      String?
  status          ContentStatus @default(draft)
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@map("music_tracks")
}

model DailyQuoteEntry {
  id         String        @id @default(cuid())
  entryDate  DateTime      @unique @db.Date
  quoteText  String
  author     String?
  status     ContentStatus @default(draft)
  publishedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status])
  @@map("daily_quote_entries")
}

model DailyPanchangEntry {
  id          String        @id @default(cuid())
  entryDate   DateTime      @unique @db.Date
  headline    String
  tithi       String
  nakshatra   String
  sunriseTime String
  sunsetTime  String
  focusText   String
  notes       String?
  status      ContentStatus @default(draft)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@map("daily_panchang_entries")
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String   @unique
  tokenId    String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Workout {
  id              String           @id @default(cuid())
  title           String
  description     String
  difficulty      WorkoutDifficulty
  durationMinutes Int
  category        String?
  tags            String[]
  status          WorkoutStatus    @default(draft)
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  exercises       WorkoutExercise[]
  sessions        WorkoutSession[]
  assignments     WorkoutAssignment[]

  @@index([status])
  @@map("workouts")
}

model WorkoutExercise {
  id                   String   @id @default(cuid())
  workoutId            String
  name                 String
  instruction          String?
  repTarget            String?
  timeTargetSeconds    Int?
  distanceTargetMeters Int?
  restSeconds          Int?
  sequence             Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  workout              Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sessionExercises     WorkoutSessionExercise[]

  @@index([workoutId])
  @@unique([workoutId, sequence])
  @@map("workout_exercises")
}

model WorkoutSession {
  id         String                 @id @default(cuid())
  workoutId  String
  userId     String
  status     WorkoutSessionStatus   @default(in_progress)
  notes      String?
  startedAt  DateTime               @default(now())
  completedAt DateTime?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  workout    Workout                @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises  WorkoutSessionExercise[]

  @@index([userId, startedAt(sort: Desc)])
  @@index([workoutId])
  @@map("workout_sessions")
}

model WorkoutSessionExercise {
  id                   String         @id @default(cuid())
  workoutSessionId     String
  workoutExerciseId    String?
  name                 String
  instruction          String?
  repTarget            String?
  timeTargetSeconds    Int?
  distanceTargetMeters Int?
  restSeconds          Int?
  sequence             Int
  completed            Boolean        @default(false)
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  workoutSession       WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  workoutExercise      WorkoutExercise? @relation(fields: [workoutExerciseId], references: [id], onDelete: SetNull)

  @@index([workoutSessionId])
  @@unique([workoutSessionId, sequence])
  @@map("workout_session_exercises")
}

model UserCoachAssignment {
  id           String   @id @default(cuid())
  userId        String   @unique
  coachId       String
  assignedById  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation("AssignedCoachForUser", fields: [userId], references: [id], onDelete: Cascade)
  coach         User     @relation("CoachAssignments", fields: [coachId], references: [id], onDelete: Cascade)
  assignedBy    User?    @relation("CoachAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([coachId])
  @@map("user_coach_assignments")
}

model WorkoutAssignment {
  id         String   @id @default(cuid())
  workoutId   String
  userId      String
  coachId     String
  note        String?
  assignedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  user        User     @relation("AssignedWorkoutsForUser", fields: [userId], references: [id], onDelete: Cascade)
  coach       User     @relation("AssignedWorkoutsByCoach", fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([workoutId, userId])
  @@index([coachId])
  @@map("workout_assignments")
}

model CoachNote {
  id         String   @id @default(cuid())
  userId      String
  coachId     String
  note        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("CoachNotesForUser", fields: [userId], references: [id], onDelete: Cascade)
  coach       User     @relation("CoachNotesByCoach", fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([userId, coachId])
  @@index([coachId])
  @@map("coach_notes")
}
