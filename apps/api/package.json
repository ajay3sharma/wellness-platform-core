{
  "name": "@platform/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ../../scripts/fix-esm-specifiers.mjs dist/apps/api/src",
    "dev": "prisma generate --schema prisma/schema.prisma && tsc-watch -p tsconfig.build.json --onSuccess \"node ../../scripts/run-api-dev-server.mjs\"",
    "lint": "eslint src --max-warnings=0",
    "start": "node dist/apps/api/src/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/schema.prisma"
  },
  "dependencies": {
    "express": "^5.1.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.0",
    "@prisma/client": "^6.0.0",
    "@platform/billing": "workspace:*",
    "@platform/brand": "workspace:*",
    "@platform/config": "workspace:*",
    "@platform/types": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "prisma": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.8.3"
  }
}
